# Merchant AI Environment Configuration

# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, claude, local
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost/merchant_ai
DATABASE_ECHO=false

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
DEBUG=true
ENVIRONMENT=development

# API Keys
RAPIDAPI_KEY=your_rapidapi_key_for_market_research
SERPAPI_KEY=your_serpapi_key_for_search
